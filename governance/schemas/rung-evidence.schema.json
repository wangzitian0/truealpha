{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truealpha.local/schemas/rung-evidence.schema.json",
  "title": "TrueAlpha RungEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "schema_version",
    "batch_id",
    "manifest_sha256",
    "accepted_rung",
    "base_sha",
    "producer_head_sha",
    "commands",
    "negative_controls",
    "stable_handoff",
    "created_at"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^rung-evidence:[a-zA-Z0-9._-]+:(?:[0-9a-f]{64}|[0-9a-f]{8}(?::[0-9a-f]{8}){7})$"
    },
    "schema_version": {"const": 1},
    "batch_id": {"type": "string", "minLength": 1},
    "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "accepted_rung": {"enum": ["E0", "E1", "E2", "E3", "E4", "E5"]},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "producer_head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "output_sha256"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "exit_code": {"const": 0},
          "output_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "negative_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "stable_handoff": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
