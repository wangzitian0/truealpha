{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truealpha.local/schemas/capability-evidence.schema.json",
  "title": "TrueAlpha CapabilityEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "issue",
    "state",
    "accepted_rung",
    "producer_commit",
    "source_pr",
    "accepted_by",
    "accepted_at",
    "commands",
    "git_objects",
    "attestation_ref",
    "claim_ceiling",
    "residual_risks"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "evidence_id": {"type": "string", "pattern": "^capability-evidence:issue-[0-9]+:v[0-9]+$"},
    "issue": {"type": "integer", "minimum": 1},
    "state": {"const": "accepted"},
    "accepted_rung": {"enum": ["E0", "E1", "E2", "E3", "E4", "E5", "GRADUATION"]},
    "producer_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source_pr": {"type": "integer", "minimum": 1},
    "accepted_by": {"type": "string", "minLength": 1},
    "accepted_at": {"type": "string", "format": "date-time"},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "git_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "oid"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "oid": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
        }
      }
    },
    "attestation_ref": {"type": "string", "minLength": 1},
    "claim_ceiling": {"type": "string", "minLength": 1},
    "residual_risks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
