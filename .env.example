# Copy to .env (gitignored). NEVER commit real credentials.

# dev | staging | prod
APP_ENV=dev

# Local dev Postgres (docker compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/truealpha
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=truealpha

# SEC requires a descriptive User-Agent with a contact email, e.g.:
# SEC_USER_AGENT=TrueAlpha research you@example.com
SEC_USER_AGENT=

# moomoo OpenD gateway — must already be running and logged into a real
# account (interactive 2FA/app confirmation, download from
# https://www.moomoo.com/download/OpenAPI). These just point at where OpenD
# is listening; they are not the account credentials.
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
# Self-imposed precautionary cap, not a real moomoo-side quota — moomoo only
# rate-limits these endpoints (bursts/30s). See init.md Section 5.
MOOMOO_MONTHLY_CALL_BUDGET=2000
