# Copy to .env (gitignored). NEVER commit real credentials.

# Runtime identity: dev | test | ci | preview | staging | prod
APP_ENV=dev
GIT_COMMIT_SHA=unknown

# PostgreSQL is both the relational system of record and the KG backend.
# Applications consume DATABASE_URL; POSTGRES_* only provision local Compose.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/truealpha
DATABASE_CONNECT_TIMEOUT_SECONDS=5
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=truealpha
POSTGRES_PORTS=127.0.0.1:5432:5432

# S3-compatible raw object storage. Local/CI Compose provides MinIO; infra2 may
# provide MinIO or another S3-compatible backend without changing app code.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_local_secret
S3_BUCKET=truealpha-raw
S3_REGION=us-east-1
S3_RAW_PREFIX=raw
S3_CONNECT_TIMEOUT_SECONDS=5
MINIO_API_PORTS=127.0.0.1:9000:9000
MINIO_CONSOLE_PORTS=127.0.0.1:9001:9001

# Compose/release controls. infra2 and GitHub CI may override these directly.
COMPOSE_PROJECT_NAME=truealpha
ENV_SUFFIX=
RESTART_POLICY=unless-stopped
IMAGE_TAG=local
REGISTRY=ghcr.io
IMAGE_PREFIX=wangzitian0/truealpha
WEB_PORTS=127.0.0.1:3000:3000
LLM_PORTS=127.0.0.1:8000:8000
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# Source-specific application configuration starts here. Runtime does not own
# these because they describe data-source behavior, not deployed dependencies.
# SEC requires a descriptive User-Agent with a contact email, e.g.:
# SEC_USER_AGENT=TrueAlpha research you@example.com
SEC_USER_AGENT=

# moomoo OpenD must already be running and interactively authenticated.
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
MOOMOO_MONTHLY_CALL_BUDGET=2000
