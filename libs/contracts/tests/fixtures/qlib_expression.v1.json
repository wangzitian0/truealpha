        "maximum_lookback_sessions": 2,
        "ast_depth": 2,
        "ast_nodes": 3
      }
    }
  ],
  "dimensionless_matrix": {
    "sessions": ["2026-01-05", "2026-01-06", "2026-01-07", "2026-01-08", "2026-01-09"],
    "instruments": {
      "SYNTH_A": {
        "growth": ["0.2", "0.4", null, "0.8", "1.0"],
        "price": ["10", "11", "11", "13", "13"],
        "quality": ["1", "2", "3", "4", "5"]
      },
      "SYNTH_B": {
        "growth": ["-0.2", "0", "0.2", null, "0.6"],
        "price": ["20", null, "22", "22", "11"],
        "quality": ["2", null, "4", "6", "8"]
      }
    },
    "expected_outputs": {
      "dimensionless-linear-blend": {
        "SYNTH_A": ["1.1", "2.2", null, "4.4", "5.5"],
        "SYNTH_B": ["1.9", null, "4.1", null, "8.3"]
      },
      "one-session-price-change": {
        "SYNTH_A": [null, "0.1", "0", "0.18181818181818182", "0"],
        "SYNTH_B": [null, null, null, "0", "-0.5"]
      },
      "three-session-quality-mean": {
        "SYNTH_A": ["1", "1.5", "2", "3", "4"],
        "SYNTH_B": ["2", "2", "3", "5", "6"]
      }
    },
    "comparison": {
      "nulls_must_match_exactly": true,
      "absolute_tolerance": "1e-12",
      "relative_tolerance": "1e-12"
    }
  },
  "negative_cases": [
    {"case_id": "raw-expression-string", "mutation": "replace root with Add($quality,$growth)", "expected_error": "invalid_expression_node"},
    {"case_id": "python-callable", "mutation": "add callable field", "expected_error": "extra_input_forbidden"},
    {"case_id": "module-path", "mutation": "add module_path field", "expected_error": "extra_input_forbidden"},
    {"case_id": "operator-kwargs", "mutation": "add kwargs field to call", "expected_error": "extra_input_forbidden"},
    {"case_id": "unsafe-field-punctuation", "mutation": "set qlib_field_name to quality);__import__('os')", "expected_error": "invalid_qlib_field_name"},
    {"case_id": "attribute-field", "mutation": "set qlib_field_name to quality.real", "expected_error": "invalid_qlib_field_name"},
    {"case_id": "index-field", "mutation": "set qlib_field_name to quality[0]", "expected_error": "invalid_qlib_field_name"},
    {"case_id": "unknown-feature", "mutation": "reference feature.unknown.v1", "expected_error": "unknown_feature_binding"},
    {"case_id": "unknown-operator", "mutation": "reference truealpha.qlib.unknown.v1", "expected_error": "unknown_operator"},
    {"case_id": "unapproved-symbol", "mutation": "set qlib_symbol to __import__", "expected_error": "unapproved_builtin_symbol"},
    {"case_id": "duplicate-operator-id", "mutation": "duplicate truealpha.qlib.add.v1", "expected_error": "duplicate_operator_id"},
    {"case_id": "duplicate-qlib-symbol", "mutation": "map a second operator to Add", "expected_error": "duplicate_qlib_symbol"},
    {"case_id": "invalid-arity", "mutation": "remove right argument from Add", "expected_error": "invalid_operator_arity"},
    {"case_id": "fractional-window", "mutation": "set Mean window to 1.5", "expected_error": "invalid_argument_kind"},
    {"case_id": "zero-window", "mutation": "set Mean window to 0", "expected_error": "invalid_argument_kind"},
    {"case_id": "nan-numeric", "mutation": "set numeric value to NaN", "expected_error": "non_finite_numeric"},
    {"case_id": "infinite-numeric", "mutation": "set numeric value to Infinity", "expected_error": "non_finite_numeric"},
    {"case_id": "excessive-depth", "mutation": "nest Add to depth 9", "expected_error": "maximum_ast_depth_exceeded"},
    {"case_id": "excessive-node-count", "mutation": "construct 65-node tree", "expected_error": "maximum_ast_nodes_exceeded"},
    {"case_id": "excessive-lookback", "mutation": "set Ref window to 253", "expected_error": "maximum_lookback_exceeded"},
    {"case_id": "duplicate-feature-binding", "mutation": "duplicate feature.quality.v1", "expected_error": "duplicate_feature_binding_id"},
    {"case_id": "stale-registry-hash", "mutation": "change an operator after computing registry hash", "expected_error": "registry_content_hash_mismatch"},
    {"case_id": "stale-expression-hash", "mutation": "change root after computing expression hash", "expected_error": "expression_content_hash_mismatch"}
  ],
  "identity_relations": [
    "operator and feature-binding input reordering does not change registry or expression semantic identity",
    "ambient Decimal precision and rounding context does not change numeric rendering or identity",
    "changing the AST, feature binding, operator semantic spec, null behavior, or derived lookback changes expression semantic identity",
    "changing only the Qlib distribution artifact or adapter implementation leaves expression semantic identity unchanged",
    "changing only the Qlib distribution artifact or adapter implementation changes combined execution identity"
  ],
  "forbidden_semantics": [
    "monetary Decimal calculation",
    "entity graph traversal",
    "point-in-time vintage selection",
    "confidence calculation",
    "source provenance branching",
    "lineage persistence",
    "provider configuration",
    "runner or replay state",
    "factor registration or release activation"
  ]
}
