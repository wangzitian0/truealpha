  "identifier_grammar": {
    "contract_id": "^[a-z][a-z0-9._-]{0,127}$",
    "qlib_field_name": "^[a-z][a-z0-9_]{0,62}$",
    "compiler_adds_field_sigil": true
  },
  "canonicalization": {
    "json": "UTF-8 JSON with sorted object keys, compact separators, and ASCII escaping",
    "decimal": "finite normalized base-10 string without exponent or trailing fractional zeroes; negative zero becomes zero",
    "operator_order": "operator_id ascending",
    "feature_binding_order": "feature_binding_id ascending",
    "required_feature_binding_order": "feature_binding_id ascending",
    "expression_semantic_identity_excludes": [
      "compiled_qlib_field",
      "qlib_distribution_artifact_sha256",
      "adapter_implementation_sha256"
    ],
    "execution_identity_includes": [
      "expression_semantic_sha256",
      "compiled_qlib_field",
      "qlib_distribution_artifact_sha256",
      "adapter_implementation_sha256"
    ]
  },
