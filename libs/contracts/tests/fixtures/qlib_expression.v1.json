  "expressions": [
    {
      "case_id": "dimensionless-linear-blend",
      "definition": {
        "factor_id": "factor.synthetic.linear_blend",
        "factor_version": "1.0.0",
        "output_kind": "dimensionless_float64",
        "null_policy": "operator_declared",
        "root": {
          "kind": "call",
          "operator_id": "truealpha.qlib.add.v1",
          "arguments": [
            {
              "kind": "feature",
              "feature_binding_id": "feature.quality.v1"
            },
            {
              "kind": "call",
              "operator_id": "truealpha.qlib.mul.v1",
              "arguments": [
                {
                  "kind": "numeric",
                  "value": "0.5"
                },
                {
                  "kind": "feature",
                  "feature_binding_id": "feature.growth.v1"
                }
              ]
            }
          ]
        }
      },
      "expected": {
        "compiled_qlib_field": "Add($quality,Mul(0.5,$growth))",
        "required_feature_binding_ids": ["feature.growth.v1", "feature.quality.v1"],
        "maximum_lookback_sessions": 0,
        "ast_depth": 3,
        "ast_nodes": 5
      }
    },
    {
      "case_id": "one-session-price-change",
      "definition": {
        "factor_id": "factor.synthetic.one_session_price_change",
        "factor_version": "1.0.0",
        "output_kind": "dimensionless_float64",
        "null_policy": "operator_declared",
        "root": {
          "kind": "call",
          "operator_id": "truealpha.qlib.div.v1",
          "arguments": [
            {
              "kind": "call",
              "operator_id": "truealpha.qlib.sub.v1",
              "arguments": [
                {
                  "kind": "feature",
                  "feature_binding_id": "feature.price.v1"
                },
                {
                  "kind": "call",
                  "operator_id": "truealpha.qlib.ref.v1",
                  "arguments": [
                    {
                      "kind": "feature",
                      "feature_binding_id": "feature.price.v1"
                    },
                    {
                      "kind": "numeric",
                      "value": "1"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "call",
              "operator_id": "truealpha.qlib.ref.v1",
              "arguments": [
                {
                  "kind": "feature",
                  "feature_binding_id": "feature.price.v1"
                },
                {
                  "kind": "numeric",
                  "value": "1"
                }
              ]
            }
          ]
        }
      },
      "expected": {
        "compiled_qlib_field": "Div(Sub($price,Ref($price,1)),Ref($price,1))",
        "required_feature_binding_ids": ["feature.price.v1"],
        "maximum_lookback_sessions": 1,
        "ast_depth": 4,
        "ast_nodes": 9
      }
    },
    {
      "case_id": "three-session-quality-mean",
      "definition": {
        "factor_id": "factor.synthetic.three_session_quality_mean",
        "factor_version": "1.0.0",
        "output_kind": "dimensionless_float64",
        "null_policy": "operator_declared",
        "root": {
          "kind": "call",
          "operator_id": "truealpha.qlib.mean.v1",
          "arguments": [
            {
              "kind": "feature",
              "feature_binding_id": "feature.quality.v1"
            },
            {
              "kind": "numeric",
              "value": "3"
            }
          ]
        }
      },
      "expected": {
        "compiled_qlib_field": "Mean($quality,3)",
